<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.CharacterRemover.CharacterRemoverController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Label fx:id="textLabel" alignment="TOP_CENTER" text="ABCDEFHIJKLMNOPQRSTUVWXYZ1234567890" textAlignment="CENTER">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <HBox alignment="TOP_CENTER" prefHeight="0.0" prefWidth="396.0" spacing="50.0">
         <children>
            <CheckBox fx:id="vowelCheckbox" mnemonicParsing="false" text="Vowels" />
            <CheckBox fx:id="consonantCheckbox" mnemonicParsing="false" text="Consonants" />
            <CheckBox fx:id="numberCheckbox" mnemonicParsing="false" text="Numbers" />
         </children>
      </HBox>
      <Button fx:id="removeButton" mnemonicParsing="false" onAction="#onButtonClickRemove" text="Remove" />
      <Button fx:id="restoreButton" mnemonicParsing="false" onAction="#onButtonClickRestore" text="Restore" />
   </children>
</VBox>
