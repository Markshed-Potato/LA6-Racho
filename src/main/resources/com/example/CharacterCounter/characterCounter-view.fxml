<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" minHeight="324.0" minWidth="397.0" prefHeight="324.0" prefWidth="397.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.CharacterCounter.CharacterCounterController">
  <padding>
    <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
  </padding>
   <TextArea fx:id="messageTextArea" prefHeight="200.0" prefWidth="200.0" />
   <HBox alignment="CENTER_LEFT" prefHeight="26.0" prefWidth="248.0" spacing="10.0">
      <children>
         <Label text="Enter Character:" />
         <TextField fx:id="characterTextField" prefHeight="26.0" prefWidth="100.0" HBox.hgrow="NEVER">
            <HBox.margin>
               <Insets right="83.0" />
            </HBox.margin>
         </TextField>
        <Button onAction="#onCountButtonClick" text="Count" textAlignment="RIGHT" />
      </children>
   </HBox>
   <HBox prefHeight="0.0" prefWidth="386.0" spacing="60.0">
      <children>
         <Label fx:id="countLabel" text="Count: 0" />
      </children>
   </HBox>
</VBox>
